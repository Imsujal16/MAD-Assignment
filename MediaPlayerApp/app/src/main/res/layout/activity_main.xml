<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- App Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 Media Player"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio &amp; Video Streaming"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- ═══════════════════════════════════════ -->
        <!-- VIDEO SECTION -->
        <!-- ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📺  VIDEO PLAYER"
            android:textColor="@color/accent_blue"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <!-- VideoView Surface -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/surface_dark"
            android:layout_marginBottom="12dp">

            <VideoView
                android:id="@+id/videoView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Placeholder overlay -->
            <LinearLayout
                android:id="@+id/videoPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textColor="@color/text_hint"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No video loaded"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- URL Input Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/etVideoUrl"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/input_bg"
                android:hint="Enter video stream URL..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:inputType="textUri"
                android:text="https://www.learningcontainer.com/wp-content/uploads/2020/05/sample-mp4-file.mp4"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnOpenUrl"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Open URL"
                android:textSize="12sp"
                android:backgroundTint="@color/accent_blue"
                android:textColor="@color/white"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </LinearLayout>

        <!-- Video Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnVideoPlay"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="▶ Play"
                android:textSize="12sp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnVideoPause"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⏸ Pause"
                android:textSize="12sp"
                android:backgroundTint="@color/accent_orange"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnVideoStop"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⏹ Stop"
                android:textSize="12sp"
                android:backgroundTint="@color/accent_red"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnVideoRestart"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="↺ Restart"
                android:textSize="11sp"
                android:backgroundTint="@color/accent_purple"
                android:textColor="@color/white" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="24dp" />

        <!-- ═══════════════════════════════════════ -->
        <!-- AUDIO SECTION -->
        <!-- ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎵  AUDIO PLAYER"
            android:textColor="@color/accent_green"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="14dp" />

        <!-- Audio Visualizer Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/surface_dark"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvAudioIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵"
                android:textSize="40sp" />

            <TextView
                android:id="@+id/tvAudioTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No file selected"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:ellipsize="middle"
                android:singleLine="true"
                android:maxWidth="280dp" />
        </LinearLayout>

        <!-- Open File Button -->
        <Button
            android:id="@+id/btnOpenFile"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📂  Open Audio File from Disk"
            android:textSize="14sp"
            android:backgroundTint="@color/accent_teal"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp" />

        <!-- Audio Status -->
        <TextView
            android:id="@+id/tvAudioStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Idle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seekBarAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/accent_green"
            android:thumbTint="@color/accent_green"
            android:layout_marginBottom="6dp" />

        <!-- Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Audio Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnAudioPlay"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="▶ Play"
                android:textSize="12sp"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnAudioPause"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⏸ Pause"
                android:textSize="12sp"
                android:backgroundTint="@color/accent_orange"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnAudioStop"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⏹ Stop"
                android:textSize="12sp"
                android:backgroundTint="@color/accent_red"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnAudioRestart"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="↺ Restart"
                android:textSize="11sp"
                android:backgroundTint="@color/accent_purple"
                android:textColor="@color/white" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
